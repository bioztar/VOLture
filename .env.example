# Interactive Brokers TWS/Gateway connection
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

# Paper trading (7497) vs Live (7496)
# IB_PORT=7496

# Kronos model path (sibling directory)
KRONOS_REPO_PATH=../kronos

# Risk limits
MAX_POSITION_SIZE=1000
MAX_PORTFOLIO_RISK_PCT=2.0
MAX_SINGLE_TRADE_RISK_PCT=0.5

# Scanner defaults
DEFAULT_TICKERS=SPY,QQQ,IWM,AAPL,MSFT,NVDA,AMZN,TSLA
SCAN_INTERVAL_SECONDS=300
MC_SAMPLES=50
PREDICTION_CANDLES=24
CANDLE_INTERVAL=1h
